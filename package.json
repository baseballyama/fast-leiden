{
  "name": "fast-leiden",
  "version": "0.0.1",
  "description": "Fast Leiden community detection for Node.js, powered by native igraph/leidenalg bindings.",
  "keywords": [
    "clustering",
    "community-detection",
    "graph",
    "igraph",
    "leiden",
    "leidenalg",
    "n-api",
    "native",
    "node-addon"
  ],
  "homepage": "https://github.com/baseballyama/fast-leiden#readme",
  "bugs": {
    "url": "https://github.com/baseballyama/fast-leiden/issues"
  },
  "license": "GPL-3.0-or-later",
  "author": "Yuichiro Yamashita",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/baseballyama/fast-leiden.git"
  },
  "files": [
    "dist",
    "native",
    "prebuilds",
    "scripts/build-deps.mjs",
    "scripts/install.mjs",
    "scripts/write-version-header.mjs",
    "binding.gyp",
    "LICENSE",
    "README.md",
    "SECURITY.md",
    "vendor/igraph/CMakeLists.txt",
    "vendor/igraph/COPYING",
    "vendor/igraph/IGRAPH_VERSION",
    "vendor/igraph/igraph.pc.in",
    "vendor/igraph/AUTHORS",
    "vendor/igraph/etc",
    "vendor/igraph/include",
    "vendor/igraph/interfaces",
    "vendor/igraph/msvc",
    "vendor/igraph/src",
    "vendor/igraph/tools",
    "vendor/igraph/vendor",
    "vendor/igraph/doc/CMakeLists.txt",
    "vendor/libleidenalg/CMakeLists.txt",
    "vendor/libleidenalg/LICENSE",
    "vendor/libleidenalg/VERSION",
    "vendor/libleidenalg/libleidenalgConfig.cmake.in",
    "vendor/libleidenalg/etc",
    "vendor/libleidenalg/include",
    "vendor/libleidenalg/src"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "install": "node scripts/install.mjs",
    "build": "pnpm build:deps && pnpm build:native && pnpm build:ts",
    "build:deps": "node scripts/build-deps.mjs",
    "build:native": "node scripts/write-version-header.mjs && node-gyp rebuild",
    "build:ts": "tsc -p tsconfig.json",
    "prebuild": "node scripts/prebuild.mjs",
    "bump-vendor": "node scripts/bump-vendor.mjs",
    "clean": "node scripts/clean.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "fuzz": "vitest run --config vitest.fuzz.config.ts",
    "bench": "pnpm build:ts && node --experimental-strip-types --no-warnings bench/basic.ts",
    "perf-gate": "pnpm build:ts && node --experimental-strip-types --no-warnings bench/perf-gate.ts",
    "soak": "pnpm build:ts && node --experimental-strip-types --no-warnings bench/soak.ts",
    "release": "pnpm build && changeset publish"
  },
  "dependencies": {
    "node-addon-api": "^8.7.0",
    "node-gyp-build": "^4.8.4"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@fast-check/vitest": "^0.3.0",
    "@types/node": "^24.12.4",
    "@vitest/coverage-v8": "^2.1.9",
    "fast-check": "^4.8.0",
    "node-gyp": "^11.5.0",
    "oxfmt": "^0.49.0",
    "oxlint": "^1.64.0",
    "prebuildify": "^6.0.1",
    "typescript": "^6.0.3",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@9.15.9"
}
