{
  "name": "fast-leiden",
  "version": "0.0.1",
  "description": "Fast Leiden community detection for Node.js, powered by native igraph/leidenalg bindings.",
  "keywords": [
    "clustering",
    "community-detection",
    "graph",
    "igraph",
    "leiden",
    "leidenalg",
    "n-api",
    "native",
    "node-addon"
  ],
  "homepage": "https://github.com/baseballyama/fast-leiden#readme",
  "bugs": {
    "url": "https://github.com/baseballyama/fast-leiden/issues"
  },
  "license": "GPL-3.0-or-later",
  "author": "Yuichiro Yamashita",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/baseballyama/fast-leiden.git"
  },
  "files": [
    "dist",
    "native",
    "vendor/igraph",
    "vendor/libleidenalg",
    "scripts/build-deps.mjs",
    "binding.gyp",
    "LICENSE",
    "README.md"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "install": "node scripts/build-deps.mjs && node scripts/write-version-header.mjs && node-gyp rebuild",
    "build": "pnpm build:deps && pnpm build:native && pnpm build:ts",
    "build:deps": "node scripts/build-deps.mjs",
    "build:native": "node scripts/write-version-header.mjs && node-gyp rebuild",
    "build:ts": "tsc -p tsconfig.json",
    "clean": "node scripts/clean.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "pnpm build:ts && node --experimental-strip-types --no-warnings bench/basic.ts",
    "release": "pnpm build && changeset publish"
  },
  "dependencies": {
    "node-addon-api": "^8.2.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10",
    "@types/node": "^24.0.0",
    "node-gyp": "^11.0.0",
    "oxfmt": "^0.49.0",
    "oxlint": "^1.64.0",
    "typescript": "^6.0.3",
    "vitest": "^2.1.6"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@9.15.0"
}
