{
  "name": "fast-leiden",
  "version": "0.0.0",
  "description": "Fast Leiden community detection for Node.js, powered by native igraph/leidenalg bindings.",
  "license": "GPL-3.0-or-later",
  "author": "Yuichiro Yamashita",
  "homepage": "https://github.com/baseballyama/fast-leiden#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/baseballyama/fast-leiden.git"
  },
  "bugs": {
    "url": "https://github.com/baseballyama/fast-leiden/issues"
  },
  "keywords": [
    "leiden",
    "leidenalg",
    "igraph",
    "community-detection",
    "graph",
    "clustering",
    "native",
    "n-api",
    "node-addon"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "native",
    "vendor/igraph",
    "vendor/leidenalg",
    "binding.gyp",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm build:native && pnpm build:ts",
    "build:native": "node-gyp rebuild",
    "build:ts": "tsc -p tsconfig.json",
    "clean": "rimraf dist build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "tsx bench/basic.ts",
    "release": "pnpm build && changeset publish"
  },
  "dependencies": {
    "node-addon-api": "^8.2.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.16.0",
    "@typescript-eslint/parser": "^8.16.0",
    "eslint": "^9.16.0",
    "node-gyp": "^11.0.0",
    "prettier": "^3.4.1",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.6"
  },
  "packageManager": "pnpm@9.15.0"
}
